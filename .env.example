# =============================================================================
#  .env.example — Copy this to .env and fill in your actual values
#  cp .env.example .env && nano .env
# =============================================================================

# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:YOUR_DB_PASSWORD@127.0.0.1:3306/payment_stock"

# JWT Secret — change to a long random string in production!
# Generate one with: openssl rand -hex 64
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_SECRET"

# Port — must match ecosystem.config.js (8080)
PORT=8080
